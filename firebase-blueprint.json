{
  "entities": {
    "Signup": {
      "title": "Signup",
      "description": "User registration for the Agave Cooperative Hub.",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Full name of the registrant."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the registrant."
        },
        "role": {
          "type": "string",
          "enum": ["grower", "processor", "agronomy_advocate", "trade_buying_agent"],
          "description": "Selected cooperative role/interest."
        },
        "enterpriseName": {
          "type": "string",
          "description": "District, province, or corporation name."
        },
        "source": {
          "type": "string",
          "description": "The component or section where they signed up."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of document creation."
        }
      },
      "required": ["fullName", "email", "role", "enterpriseName", "source", "createdAt"]
    }
  },
  "firestore": {
    "/signups/{signupId}": {
      "schema": "Signup",
      "description": "Individual cooperative registrants."
    }
  }
}
