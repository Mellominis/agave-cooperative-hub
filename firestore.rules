rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Global default: deny everything not explicitly allowed ──────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ─────────────────────────────────────────────────────────────

    // Document ID must be a valid Firebase Auth UID (28 alphanumeric chars)
    function isAuthUid(id) {
      return id is string && id.size() >= 20 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    // Validates the full shape that SignupForm.tsx writes
    function isValidSignup(data) {
      return data.keys().hasAll([
          'uid', 'fullName', 'email', 'role', 'enterpriseName',
          'source', 'createdAt', 'registeredAt',
          'status', 'approvedAt', 'country', 'sector'
        ])
        // uid must match the authenticated user making the request
        && data.uid == request.auth.uid
        // String length guards
        && data.fullName  is string && data.fullName.size()  > 0  && data.fullName.size()  <= 200
        && data.email     is string && data.email.size()     > 0  && data.email.size()     <= 200
        && data.role      is string && data.role      in ['grower', 'processor', 'agronomy_advocate', 'trade_buying_agent']
        && data.enterpriseName is string && data.enterpriseName.size() <= 200
        && data.source    is string && data.source.size()    <= 200
        && data.createdAt is string && data.createdAt.size() <= 50
        && data.registeredAt is string && data.registeredAt.size() <= 50
        // Approval workflow fields
        && data.status    in ['pending', 'approved']
        && data.country   is string
        && data.sector    is string;
    }

    // ── /apps/{country}/signups/{uid} ────────────────────────────────────────
    // Matches the exact path used by SignupForm: apps/zimbabwe/signups/{uid}
    match /apps/{country}/signups/{uid} {

      // CREATE — only the authenticated user can create their own document
      // and the payload must pass schema validation
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && isAuthUid(uid)
                    && isValidSignup(incoming());

      // READ — a user can only read their own signup doc
      // (used by SignInForm to restore the session)
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      // UPDATE — allow the same user to update (merge: true re-submission)
      // Only non-sensitive fields can change; status & approvedAt are admin-only
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && incoming().status == resource.data.status
                    && incoming().approvedAt == resource.data.approvedAt;

      // DELETE — never allowed from the client
      allow delete: if false;
    }
  }
}
