rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net: secure deny-all default
    match /{document=**} {
      allow read, write: if false;
    }

    // Global utility helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile matching
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User Meal items
    match /users/{userId}/meals/{mealId} {
      allow read, write: if isOwner(userId) && isValidId(mealId);
    }

    // User Health check-ins
    match /users/{userId}/checkins/{checkinId} {
      allow read, write: if isOwner(userId) && isValidId(checkinId);
    }

    // User streak configuration
    match /users/{userId}/meta/streak {
      allow read, write: if isOwner(userId);
    }
  }
}
